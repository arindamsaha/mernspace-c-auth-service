   "devDependencies": {
      "@eslint/js": "^10.0.1",
      "@types/express": "^5.0.6",
      "@types/http-errors": "^2.0.5",
      "@types/jest": "^30.0.0",
      "@types/node": "^25.9.1",
      "@types/supertest": "^7.2.0",
      "@types/winston": "^2.4.4",
      "cross-env": "^10.1.0",
      "eslint": "^10.4.0",
      "globals": "^17.6.0",
      "jest": "^30.4.2",
      "jiti": "^2.7.0",
      "nodemon": "^3.1.14",
      "prettier": "3.8.3",
      "supertest": "^7.2.2",
      "ts-jest": "^29.4.11",
      "ts-node": "^10.9.2",
      "tsx": "^4.22.3",
      "typescript": "^6.0.3",
      "typescript-eslint": "^8.59.4"
   },
   "dependencies": {
      "dotenv": "^17.4.2",
      "express": "^5.2.1",
      "http-errors": "^2.0.1",
      "reflect-metadata": "^0.2.2",
      "typeorm": "1.0.0",
      "winston": "^3.19.0"
